# Hermes Dashboard Environment Variables
# Copy this file to /etc/hermes-dashboard/hermes-dashboard.env and fill in the values

# === Required ===
HERMES_APP_DIR=/opt/hermes/sembako-dashboard
HERMES_DATA_DIR=/var/lib/hermes-dashboard/data
HERMES_CACHE_DIR=/var/lib/hermes-dashboard/cache
HERMES_LOG_DIR=/var/log/hermes-dashboard
HERMES_STATE_DIR=/home/hermes/.hermes
TZ=Asia/Jakarta

# === Secrets (DO NOT commit to Git) ===
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TELEGRAM_BOT_TOKEN=1234567890:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TELEGRAM_CHAT_ID=123456789

# === Optional ===
# WORDPRESS_EMAIL=your_email@example.com
# WORDPRESS_APP_PASSWORD=xxxxxxxxxxxxxxxxxxxxxxxx
# DOMAIN_NAME=example.com

# === Backup (optional) ===
# BACKUP_ENCRYPTION_RECIPIENT=/path/to/age-recipient.txt
# OFFSITE_BACKUP_DIR=/path/to/offsite/storage
